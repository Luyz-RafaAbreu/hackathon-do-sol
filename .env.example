# ============================================================================
# HACKATHON DO SOL — variáveis de ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para ".env.local" e preencha os valores reais.
# .env.local NÃO é commitado no git (está no .gitignore).
# ============================================================================

# URL pública do site (usada em metadata SEO).
# Em dev pode deixar http://localhost:3000. Em produção, a URL final.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Integração com Google Sheets via Apps Script
# ----------------------------------------------------------------------------
# 1. Siga o SETUP em scripts/apps-script.gs
# 2. Após publicar como Web App, cole aqui a URL gerada
#    (algo como https://script.google.com/macros/s/AKfycb.../exec)
APPS_SCRIPT_WEBHOOK_URL=

# Token secreto — DEVE ser IGUAL ao WEBHOOK_SECRET definido no topo
# do arquivo scripts/apps-script.gs. Gere algo aleatório, exemplo:
#   openssl rand -hex 32
# ou no console do navegador:
#   crypto.randomUUID()
APPS_SCRIPT_WEBHOOK_SECRET=
