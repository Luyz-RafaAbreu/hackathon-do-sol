# ============================================================================
# HACKATHON DO SOL — variáveis de ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para ".env.local" e preencha os valores reais.
# .env.local NÃO é commitado no git (está no .gitignore).
# ============================================================================

# URL pública do site (usada em metadata SEO).
# Em dev pode deixar http://localhost:3001. Em produção, a URL final.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Integração com Google Sheets via Apps Script
# ----------------------------------------------------------------------------
# 1. Siga o SETUP em scripts/apps-script.gs
# 2. Após publicar como Web App, cole aqui a URL gerada
#    (algo como https://script.google.com/macros/s/AKfycb.../exec)
APPS_SCRIPT_WEBHOOK_URL=

# Token secreto — DEVE ser IGUAL ao WEBHOOK_SECRET definido no topo
# do arquivo scripts/apps-script.gs. Gere algo aleatório, exemplo:
#   openssl rand -hex 32
# ou no console do navegador:
#   crypto.randomUUID()
APPS_SCRIPT_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Cloudflare Turnstile — captcha do formulário
# ----------------------------------------------------------------------------
# 1. Crie um widget em https://dash.cloudflare.com/?to=/:account/turnstile
# 2. Configure os hostnames (localhost + domínio de produção)
# 3. Cole as keys aqui:
#    - SITE_KEY é pública (vai no client)
#    - SECRET_KEY é privada (só servidor) — NÃO commitar
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Google OAuth (NextAuth) — autenticação obrigatória pra /inscricao
# ----------------------------------------------------------------------------
# 1. Acesse https://console.cloud.google.com/apis/credentials
# 2. Crie um projeto novo (ex: "Hackathon do Sol") ou use um existente
# 3. APIs & Services → OAuth consent screen:
#      - User Type: External
#      - App name: Hackathon do Sol
#      - Support email + Developer contact: seu e-mail
#      - Scopes: deixar padrão (email + profile + openid)
#      - Test users: enquanto não publicar, só esses logam
# 4. Credentials → Create Credentials → OAuth client ID:
#      - Application type: Web application
#      - Authorized JavaScript origins:
#          http://localhost:3001
#          https://hackathondosol.com.br  (e/ou alias da Vercel)
#      - Authorized redirect URIs:
#          http://localhost:3001/api/auth/callback/google
#          https://hackathondosol.com.br/api/auth/callback/google
# 5. Copie o Client ID e Client Secret aqui:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret pra assinar os JWTs do NextAuth. Gere com:
#   openssl rand -base64 32
# (ou no console do navegador: btoa(crypto.getRandomValues(new Uint8Array(32))))
NEXTAUTH_SECRET=

# URL base do site — usada pelo NextAuth pra montar callbacks.
# Em dev: http://localhost:3001  |  Em prod: https://hackathondosol.com.br
NEXTAUTH_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Upstash Redis — backup server-side dos rascunhos do formulário
# ----------------------------------------------------------------------------
# Faz o draft do formulário sincronizar entre dispositivos. Sem isso, o
# rascunho continua salvo só no navegador (localStorage), o que ainda cobre
# os casos de F5/fechar aba.
#
# 1. Cria conta grátis em https://console.upstash.com
# 2. Create Database → Redis → escolhe região mais próxima (sa-east-1)
# 3. Na página do DB, aba "REST API" — copia as duas envs abaixo:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
